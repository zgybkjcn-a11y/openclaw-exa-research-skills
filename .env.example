# OpenClaw Exa Research Skills - Environment Template
# Copy this file to .env for local testing if your OpenClaw/tooling reads env files.
# DO NOT commit .env. Keep real API keys private.

# Exa API key (for environments/tools that expose exa_search via env)
EXA_API_KEY="YOUR_EXA_API_KEY_HERE"

# Tavily API key (optional, for tavily_search / dual_search depending on your OpenClaw plugin setup)
TAVILY_API_KEY="YOUR_TAVILY_API_KEY_HERE"

# Grok / xAI API key (optional, for grok_search / Twitter/X search depending on your setup)
XAI_API_KEY="YOUR_XAI_API_KEY_HERE"
GROK_API_KEY="YOUR_GROK_API_KEY_HERE"

# Generic provider keys sometimes used by OpenClaw plugins/providers.
# Leave unused values as placeholders or remove them in your private .env.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY_HERE"
ANTHROPIC_API_KEY="YOUR_ANTHROPIC_API_KEY_HERE"

# Optional proxy for WSL/corporate network environments.
# Example: http://127.0.0.1:7890
HTTP_PROXY=""
HTTPS_PROXY=""
ALL_PROXY=""
